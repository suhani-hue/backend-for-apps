{
  "name": "backend_for_apps",
  "version": "1.0.0",
  "description": "A reusable Backend-as-a-Service (BaaS) built with Express, Prisma, JWT auth, and SQLite.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "lint": "eslint src/**/*.js tests/**/*.js"
  },
  "dependencies": {
    "@prisma/client": "^5.13.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "eslint": "^9.3.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
